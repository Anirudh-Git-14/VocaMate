<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_main"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txtAccountInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account: Loading..."
            android:textColor="@color/text_main"
            android:textSize="17sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About VocaMate"
            android:textColor="@color/primary_green_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VocaMate is an AI voice speaking practice app. It helps users improve speaking confidence through real-time voice conversation and mistake reports."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Modes"
            android:textColor="@color/primary_green_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Friend Mode\n• HR Interview Mode\n• Manager Mode\n• Parent Mode\n• Partner Mode"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How to Use"
            android:textColor="@color/primary_green_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Choose a language\n2. Choose a practice mode\n3. Speak naturally\n4. Listen to the AI reply\n5. Generate your mistake report"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Help and Queries"
            android:textColor="@color/primary_green_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="For help, feedback, or project queries, contact:\nguruanirudhpathi@gmail.com"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/bg_dark"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="24dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="made by Anirudh"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:alpha="0.35" />

    </LinearLayout>
</ScrollView>